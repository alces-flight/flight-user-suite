#!/usr/bin/env python3
import re
import sys

def main():
    if len(sys.argv) not in [3, 4]:
        print("Usage augment-bash-prompt <PS1> <injection> [<colour>]")
        sys.exit(1)

    ps1 = sys.argv[1]
    injection = sys.argv[2]
    if len(sys.argv) > 3:
        colour = sys.argv[3]
        injection = f"\\[\\e[{colour}m\\]{injection}\\[\\e[0m\\]"

    inside_escape_sequence = False
    injected = False

    # Split into PS1 escape segments and non-escape text
    parts = re.split(r'(\\\[)(.*?)(\\\])', ps1)
    mapped = []

    for x in parts:
        if x == r'\[':
            inside_escape_sequence = True
        elif x == r'\]':
            inside_escape_sequence = False
        elif not inside_escape_sequence and not injected:
            if r'\h' in x:
                x = x.replace(r'\h', f"\\h {injection}", 1)
                injected = True
            elif r'\W' in x:
                x = x.replace(r'\W', f"{injection} \\W", 1)
                injected = True
            elif r'\w' in x:
                x = x.replace(r'\w', f"{injection} \\w", 1)
                injected = True
            elif r'\$' in x:
                x = x.replace(r'\$', f"{injection} \\$", 1)
                injected = True
        mapped.append(x)

    print("".join(mapped))

if __name__ == "__main__":
  main()
