{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "252",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#209FCE",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#FFFDF5",
    "background_color": "#2186CE"
  },
  "h2": {
    "prefix": "\n",
    "color": "#41C2F2"
  },
  "h3": {
  },
  "h4": {
    "prefix": "# "
  },
  "h5": {
    "prefix": "## "
  },
  "h6": {
    "color": "#CCD0DA"
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "240",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "\u001b[38;5;32;159;206m• \u001b[0m"
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#83D0ED",
    "underline": true
  },
  "link_text": {
    "color": "#CCD0DA",
    "bold": true
  },
  "image": {
    "color": "212",
    "underline": true
  },
  "image_text": {
    "color": "243",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#CCD0DA",
    "background_color": "#3D424A"
  },
  "code_block": {
    "margin": 4,
    "color": "#A2A7B4"
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
