{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "234",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#5FBBDD",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#FFFDF5",
    "background_color": "#209FCE"
  },
  "h2": {
    "prefix": "\n",
    "color": "#209FCE"
  },
  "h3": {
  },
  "h4": {
    "prefix": "# "
  },
  "h5": {
    "prefix": "## "
  },
  "h6": {
    "color": "#2C3E50"
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "249",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "\u001b[38;5;32;159;206m• \u001b[0m"
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#2C3E50",
    "underline": true
  },
  "link_text": {
    "color": "#2C3E50",
    "bold": true
  },
  "image": {
    "color": "205",
    "underline": true
  },
  "image_text": {
    "color": "243",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#2C3E50",
    "background_color": "#E0E4EA"
  },
  "code_block": {
    "margin": 4,
    "color": "#7F8594"
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
